{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile-multiverso",
			"type": "shell",
			"command": "javac",
			"args": [
				"-encoding",
				"UTF-8",
				"-d",
				"out",
				"src/Main.java",
				"src/combate/*.java",
				"src/controlador/*.java",
				"src/grafo/*.java",
				"src/modelo/*.java",
				"src/vista/*.java"
			],
			"isBackground": false,
			"problemMatcher": [
				"$javac"
			],
			"group": "build"
		}
	]
}